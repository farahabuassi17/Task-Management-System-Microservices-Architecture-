type Query {
  task(id: ID!): Task
}

type Mutation {
  createTask(input: CreateTaskInput!): Task!
}

type Task {
  id: ID!
  title: String!
  description: String!
  status: String!
  assignedUserId: String!
  assignedUserName: String!
  assignedUserEmail: String!
  createdAt: String!
}

input CreateTaskInput {
  title: String!
  description: String!
  assignedUserId: String!
}
